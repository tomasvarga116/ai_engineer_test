# Copy to `.env` and fill in. `.env` is gitignored.
#
# We use OpenRouter (https://openrouter.ai) which exposes an OpenAI-compatible
# API surface, so the official `openai` Python SDK works as-is when pointed at
# the OpenRouter base URL. Any provider's OpenAI-compatible endpoint works the
# same way - just change OPENAI_BASE_URL and OPENAI_MODEL.

OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemini-2.5-flash

# Optional
# LOG_LEVEL=INFO
